{
  "name": "lib-npm",
  "private": true,
  "scripts": {
    "build": "pnpm -r --filter './packages/*' build",
    "typecheck": "pnpm -r --filter './packages/*' typecheck",
    "clean": "pnpm -r --filter './packages/*' clean",
    "test": "pnpm -r --filter './packages/*' test",
    "test:watch": "pnpm -r --filter './packages/*' test:watch",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^3.2.6",
    "@changesets/cli": "^2.27.0"
  },
  "packageManager": "pnpm@11.6.0+sha512.9a36518224080c6fe5165afdcfe79bfa118c29be703f3f462b1e32efe1e98e47e8750b148e08286250aad4113cc7993ca413c4e2cd447752708c2ee5751bc95f"
}
