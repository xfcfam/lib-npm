# ────────────────────────────────────────────────────────────────
#  Dependencies — regenerated by `pnpm install`
# ────────────────────────────────────────────────────────────────
node_modules/

# pnpm
.pnpm-store/
.pnpm-debug.log*

# ────────────────────────────────────────────────────────────────
#  Lock-file guard — this monorepo uses pnpm. npm and yarn
#  lockfiles here would mean someone ran the wrong install command.
#  (pnpm-lock.yaml IS committed as the source of truth.)
# ────────────────────────────────────────────────────────────────
package-lock.json
yarn.lock

# ────────────────────────────────────────────────────────────────
#  Build artefacts — regenerated by `pnpm build`
# ────────────────────────────────────────────────────────────────
# Each package emits to its own /dist (configured in tsconfig.json
# `outDir`). The `files` field in each package.json controls what
# ships to npm; nothing here goes to git.
dist/
build/

# TypeScript incremental compile state
*.tsbuildinfo
tsconfig.tsbuildinfo

# npm pack output (release tarballs)
*.tgz

# ────────────────────────────────────────────────────────────────
#  Test coverage and caches
# ────────────────────────────────────────────────────────────────
coverage/
.nyc_output/
.vitest-cache/
.vitest/

# ────────────────────────────────────────────────────────────────
#  Misc tool caches
# ────────────────────────────────────────────────────────────────
.cache/
.turbo/
.eslintcache
.parcel-cache/
.next/
.nuxt/

# ────────────────────────────────────────────────────────────────
#  Logs
# ────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ────────────────────────────────────────────────────────────────
#  Environment variables — never commit secrets
# ────────────────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ────────────────────────────────────────────────────────────────
#  Editor / IDE — kept out so each contributor can use their own
# ────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.iml
.history/
*.swp
*.swo
*.sublime-*

# ────────────────────────────────────────────────────────────────
#  Backup / merge-conflict leftovers
# ────────────────────────────────────────────────────────────────
*.bak
*.orig
*.rej
*~

# ────────────────────────────────────────────────────────────────
#  Operating system
# ────────────────────────────────────────────────────────────────
.DS_Store
._*
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ────────────────────────────────────────────────────────────────
#  Maintainer-only setup tooling lives in the XFAorg umbrella
#  (03-code/scripts/), NOT in this public repo.
# ────────────────────────────────────────────────────────────────
scripts/
